---
import "../style.css";
---

<script>
  const header = document.getElementById("mainHeader");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header.classList.add("scrolled");
    } else {
      header.classList.remove("scrolled");
    }
  });
</script>
<header
  id="mainHeader"
  class="fixed top-0 left-0 w-full z-50 flex items-center justify-center border-b border-solid border-slate-700/50 bg-[#0f172b75] glass-header"
>
  <div
    class="flex items-center justify-between w-full max-w-[1200px] px-6 lg:px-10 py-4"
  >
    <div class="flex items-center gap-3">
      <div class="size-6 hover:text-[#3c3cf6]">
        <svg
          fill="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"></path>
        </svg>
      </div>
      <h2
        class="text-xl font-bold font-display leading-tight tracking-tight text-white"
      >
        TechWeb Agency
      </h2>
    </div>
    <div class="hidden md:flex flex-1 justify-end gap-8 items-center">
      <nav class="flex items-center gap-8">
        <a
          class="text-sm font-medium leading-normal text-slate-300 hover:text-[#3c3cf6] transition-colors"
          href="#">Servicios</a
        >
        <a
          class="text-sm font-medium leading-normal text-slate-300 hover:text-[#3c3cf6] transition-colors"
          href="#">Portafolio</a
        >
        <a
          class="text-sm font-medium leading-normal text-slate-300 hover:text-[#3c3cf6] transition-colors"
          href="#">Nosotros</a
        >
        <a
          class="text-sm font-medium leading-normal text-slate-300 hover:text-[#3c3cf6] transition-colors"
          href="#">Contacto</a
        >
      </nav>
      <button
        class="flex items-center justify-center rounded-lg h-10 px-5 bg-primary text-white text-sm font-bold leading-normal tracking-wide hover:bg-[#3c3cf6e6]/90 cursor-pointer transition-all shadow-lg hover:shadow-blue-500/30"
      >
        <span class="truncate">Solicitar Cotización</span>
      </button>
    </div>
    <button class="md:hidden text-white">
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
</header>
